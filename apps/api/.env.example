GIGASTUDY_API_APP_ENV=development
GIGASTUDY_API_STORAGE_ROOT=./storage
GIGASTUDY_API_MAX_UPLOAD_BYTES=15728640
GIGASTUDY_API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
GIGASTUDY_API_DOCUMENT_EXTRACTION_BACKEND=auto
GIGASTUDY_API_DOCUMENT_PREPROCESS_MODE=retry
GIGASTUDY_API_DOCUMENT_PREPROCESS_DPI=300
# Optional admin access. Prefer token auth for deployed admin pages.
# GIGASTUDY_API_ADMIN_TOKEN=<admin-token>
# GIGASTUDY_API_ADMIN_PASSWORD=<admin-password>
# auto tries Basic Pitch if separately installed, then librosa pYIN, then the
# built-in local autocorrelation fallback. Force "librosa" or "local" for tests.
GIGASTUDY_API_VOICE_TRANSCRIPTION_BACKEND=auto

# Optional durable metadata store. Leave empty for local JSON development.
# GIGASTUDY_API_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional durable asset store. Use with Cloudflare R2 or another S3-compatible
# bucket. Leave GIGASTUDY_API_STORAGE_BACKEND=local for local filesystem storage.
# GIGASTUDY_API_STORAGE_BACKEND=s3
# GIGASTUDY_API_S3_BUCKET=gigastudy-alpha
# GIGASTUDY_API_S3_REGION=auto
# GIGASTUDY_API_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# GIGASTUDY_API_S3_ACCESS_KEY_ID=<access-key-id>
# GIGASTUDY_API_S3_SECRET_ACCESS_KEY=<secret-access-key>
# GIGASTUDY_API_S3_ADDRESSING_STYLE=path

# Optional low-cost LLM harmony planner. Local development reads this file as
# apps/api/.env. Production should put the API key in Cloud Run env vars or
# Secret Manager; never commit a real key.
# GIGASTUDY_API_DEEPSEEK_HARMONY_ENABLED=true
# GIGASTUDY_API_DEEPSEEK_MIDI_ROLE_REVIEW_ENABLED=false
# GIGASTUDY_API_DEEPSEEK_REGISTRATION_REVIEW_ENABLED=false
# GIGASTUDY_API_DEEPSEEK_ENSEMBLE_REVIEW_ENABLED=false
# GIGASTUDY_API_DEEPSEEK_API_KEY=<openrouter-or-deepseek-api-key>
#
# OpenRouter free route:
# GIGASTUDY_API_DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
# GIGASTUDY_API_DEEPSEEK_MODEL=deepseek/deepseek-v4-flash:free
# GIGASTUDY_API_DEEPSEEK_SITE_URL=https://gigastudy-alpha.pages.dev
# GIGASTUDY_API_DEEPSEEK_APP_TITLE=GigaStudy Alpha
#
# Native DeepSeek route:
# GIGASTUDY_API_DEEPSEEK_BASE_URL=https://api.deepseek.com
# GIGASTUDY_API_DEEPSEEK_MODEL=deepseek-v4-flash
# GIGASTUDY_API_DEEPSEEK_THINKING_ENABLED=false
# GIGASTUDY_API_DEEPSEEK_TIMEOUT_SECONDS=8
# GIGASTUDY_API_DEEPSEEK_MAX_RETRIES=1
# GIGASTUDY_API_DEEPSEEK_REVISION_CYCLES=1
# GIGASTUDY_API_DEEPSEEK_MAX_TOKENS=1800
