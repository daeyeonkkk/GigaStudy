GIGASTUDY_API_ENV=production
GIGASTUDY_API_APP_NAME=GigaStudy API
GIGASTUDY_API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
GIGASTUDY_API_PUBLIC_APP_URL=http://127.0.0.1:5173
GIGASTUDY_API_DATABASE_URL=postgresql+psycopg://gigastudy:gigastudy@127.0.0.1:5432/gigastudy
GIGASTUDY_API_DATABASE_ECHO=false
GIGASTUDY_API_DEFAULT_USER_NICKNAME=local-dev
GIGASTUDY_API_STORAGE_BACKEND=s3
GIGASTUDY_API_STORAGE_ROOT=./storage
GIGASTUDY_API_S3_BUCKET=gigastudy
GIGASTUDY_API_S3_REGION=ap-northeast-2
GIGASTUDY_API_S3_ENDPOINT_URL=http://127.0.0.1:9000
GIGASTUDY_API_S3_ACCESS_KEY_ID=minioadmin
GIGASTUDY_API_S3_SECRET_ACCESS_KEY=minioadmin
GIGASTUDY_API_S3_SESSION_TOKEN=
GIGASTUDY_API_S3_ADDRESSING_STYLE=path
GIGASTUDY_API_BASIC_PITCH_NODE_BINARY=node
GIGASTUDY_API_BASIC_PITCH_TIMEOUT_SECONDS=90
