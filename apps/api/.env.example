GIGASTUDY_API_APP_ENV=development
GIGASTUDY_API_STORAGE_ROOT=./storage
GIGASTUDY_API_MAX_UPLOAD_BYTES=15728640
GIGASTUDY_API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional durable metadata store. Leave empty for local JSON development.
# GIGASTUDY_API_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional durable asset store. Use with Cloudflare R2 or another S3-compatible
# bucket. Leave GIGASTUDY_API_STORAGE_BACKEND=local for local filesystem storage.
# GIGASTUDY_API_STORAGE_BACKEND=s3
# GIGASTUDY_API_S3_BUCKET=gigastudy-alpha
# GIGASTUDY_API_S3_REGION=auto
# GIGASTUDY_API_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# GIGASTUDY_API_S3_ACCESS_KEY_ID=<access-key-id>
# GIGASTUDY_API_S3_SECRET_ACCESS_KEY=<secret-access-key>
# GIGASTUDY_API_S3_ADDRESSING_STYLE=path
