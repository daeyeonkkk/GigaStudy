{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://gigastudy-alpha.pages.dev",
          "http://localhost:5173",
          "http://127.0.0.1:5173"
        ],
        "methods": [
          "PUT",
          "GET",
          "HEAD"
        ],
        "headers": [
          "Content-Type",
          "content-type"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
